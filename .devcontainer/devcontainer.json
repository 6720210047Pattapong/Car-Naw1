{
  "name": "Car Booking System (Earth)",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",

  "features": {
    "ghcr.io/devcontainers-contrib/features/mysql-server:1": {
      "version": "8.0"
    }
  },

  "forwardPorts": [3010, 5001],
  "portsAttributes": {
    "3010": { "label": "Frontend (Vite)", "onAutoForward": "openBrowser" },
    "5001": { "label": "Backend (API)" }
  },

  "postCreateCommand": "npm install",
  "postStartCommand": "bash .devcontainer/startup.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      }
    }
  }
}
