# ===================================================
#  Car Booking System — ตัวอย่างไฟล์ Environment
#  คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าจริงของคุณ
# ===================================================

# --- Database (MySQL) ---
DB_HOST=localhost
DB_PORT=3008
DB_NAME=earth_db
DB_USER=earth
DB_PASSWORD=earth123

# --- Server ---
PORT=5001

# --- สำหรับ GitHub Codespaces ---
# ค่า default ด้านบนใช้ได้กับ Codespaces โดยตรง
# (startup.sh จะสร้าง user 'earth' / password 'earth123' ให้อัตโนมัติ)